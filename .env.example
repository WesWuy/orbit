# Orbit Configuration
ORBIT_ENV=development
ORBIT_HOST=0.0.0.0
ORBIT_PORT=8000

# Simulation
SIM_TICK_RATE_HZ=50
SIM_REALTIME=true

# Safety limits
MAX_SPEED_MS=5.0
MAX_ALTITUDE_M=30.0
MIN_ALTITUDE_M=1.0
BATTERY_WARN_PCT=20
BATTERY_CRITICAL_PCT=10
GEOFENCE_RADIUS_M=100.0

# Logging
LOG_LEVEL=INFO
LOG_TELEMETRY=true
